# ====================================
# Lark Configuration
# ====================================
# App 생성: https://open.larksuite.com
# 1. "Create App" → App Name: "Daily Focus"
# 2. App ID와 App Secret 복사
# 3. Permissions: calendar:calendar, im:message, im:message:send_as_bot, im:chat
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxx

# User Access Token (OAuth로 자동 발급됨, 캘린더 접근용)
# 발급 방법: python3 scripts/lark_oauth.py
LARK_USER_TOKEN=

# User Open ID (OAuth 로그인 시 자동 저장)
LARK_USER_OPEN_ID=ou_xxxxxxxxxxxx

# Group Chat ID (봇과 대화할 그룹 채팅)
# 설정 방법: Lark에서 그룹 생성 → 봇 초대 → python3 scripts/lark_chat_discovery.py
LARK_CHAT_ID=oc_xxxxxxxxxxxx

# ====================================
# Gemini Configuration (Primary AI)
# ====================================
# API Key 발급: https://aistudio.google.com/apikey
# 스콥 분석 + Coach 피드백에 사용됨
GEMINI_API_KEY=xxxxxxxxxxxx

# ====================================
# Anthropic Configuration (Fallback)
# ====================================
# API Key 발급: https://console.anthropic.com/settings/keys
# 스콥 분석 fallback으로 사용됨
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ====================================
# OpenAI Configuration (Fallback)
# ====================================
# API Key 발급: https://platform.openai.com/api-keys
# 스콥 분석 fallback으로 사용됨
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# ====================================
# Google Calendar Configuration
# ====================================
# Service Account 키: Google Cloud Console > IAM > Service Accounts > Create Key (JSON)
# 캘린더 공유: Google Calendar > 설정 > 특정 사용자와 공유 > Service Account 이메일 추가 (세부정보 보기)
# 파일 경로 또는 JSON 문자열 (CI/CD용)
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
# 동기화할 Google Calendar ID (보통 Gmail 주소)
GOOGLE_CALENDAR_ID=user@example.com

# ====================================
# Schedule Configuration (선택)
# ====================================
# cron job으로 자동 실행 (경로는 본인의 실제 경로로 수정)
# crontab -e
# 0 22 * * * cd /Users/damee/dev/my-first-skill/daily-focus && /usr/bin/python3 nightly_flow.py >> ~/daily-focus.log 2>&1
